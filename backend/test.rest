### Obtenir mes informations d'utilisateur
GET {{baseUrl}}/auth/me
Authorization: Bearer {{authToken}}


######### REQUETES MONSTRES ###################

### Afficher tous les monstres (PUBLIC)
GET {{baseUrl}}/monstre/

### afficher 1 monstre par son nom (PUBLIC)
GET {{baseUrl}}/monstre/goblin

### Ajout de monstre (MDJ)
POST {{baseUrl}}/monstre/ajouter/orc
Authorization: Bearer {{authTokenAdmin}}

### Ajout de monstre (MDJ)
POST {{baseUrl}}/monstre/ajouter/goblin
Authorization: Bearer {{authTokenAdmin}}

### Suppression de monstre par nom (MDJ)
DELETE {{baseUrl}}/monstre/supprimer/orc
Authorization: Bearer {{authTokenAdmin}}

### Modification du monstre par nom (changement de nom et changement de la stat attaque) (MDJ)
PATCH {{baseUrl}}/monstre/goblin
Content-Type: application/json
Authorization: Bearer {{authTokenAdmin}}

{
    "nom":"Goblin ++",
    "attaque": 50
}

### Suppression du nouveau monstre cree lors de la modification (MDJ)
DELETE {{baseUrl}}/monstre/supprimer/goblin%20++
Authorization: Bearer {{authTokenAdmin}}

