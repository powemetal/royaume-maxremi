### Variables globales
@baseUrl = http://localhost:3000

######### REQUETES AUTH #########

### Créer un compte comme utilisateur
POST http://localhost:3000/auth/register
Content-Type: application/json

{
    "email": "math_le_barbare@waaagh.com",
    "pseudo": "DakkaBoii",
    "mdp": "WaaAgh247!"
}

### Login dans un compte comme utilisateur avec infos OK
# @name loginReq
POST http://localhost:3000/auth/login
Content-Type: application/json

{
    "email": "math_le_barbare@waaagh.com",
    "mdp": "WaaAgh247!"
}

### authToken garde en mémoire le token du login pour l'utiliser dans d'autres routes
@authToken = {{loginReq.response.body.token}}

### Login dans un compte comme utilisateur avec un mauvais MDP
POST http://localhost:3000/auth/login
Content-Type: application/json

{
    "email": "math_le_barbare@waaagh.com",
    "mdp": "wAAaGH247!"
}

### Login dans un compte comme utilisateur avec un mauvais pseudo
POST http://localhost:3000/auth/login
Content-Type: application/json

{
    "email": "math_le_barbare@waagh.com",
    "mdp": "WaaAgh247!"
}

### Obtenir mes informations d'utilisateur
GET http://localhost:3000/auth/me
Authorization: Bearer {{authToken}}


######### REQUETES MONSTRES SANS TOKEN ###################

### Afficher tous les monstres
GET http://localhost:3000/monstre/

### afficher 1 monstre par son nom
GET http://localhost:3000/monstre/goblin

### Ajout de monstre (sans token pour le moment)
POST http://localhost:3000/monstre/ajouter/orc

### Ajout de monstre (sans token pour le moment)
POST http://localhost:3000/monstre/ajouter/goblin

### Suppression de monstre par nom (sans token pour le moment)
DELETE http://localhost:3000/monstre/supprimer/orc


### Modification du monstre par nom (changement de nom et changement de la stat attaque)
PATCH HTTP://localhost:3000/monstre/goblin
Content-Type: application/json

{
    "nom":"Goblin ++",
    "attaque": 50
}

### Suppression du nouveau monstre cree lors de la modification
DELETE http://localhost:3000/monstre/supprimer/goblin%20++

