// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Role{
  JOUEUR
  MAITRE_DU_JEU
}

enum Rarete{
  COMMUN
  PEU_COMMUN
  RARE
  LEGENDAIRE
}

enum Difficulte{
  FACILE
  MOYEN
  DIFFICILE
  LEGENDAIRE
}

enum Statut{
  DISPONIBLE
  EN_COURS
  TERMINE
  ECHOUE
}

enum Classe{
  GUERRIER
  MAGE
  VOLEUR
  CLERC
}

model Monstre {
  id                String          @id @default(uuid()) @db.Uuid
  nom               String          @unique
  pointsDeVie       Int             @default(100)
  attaque           Int
}

model Objet{
  id                String          @id @default(uuid()) @db.Uuid
  nom               String          @unique
  rarete            Rarete
  inventaire        Inventaire[]
}



model Utilisateur{
  id                 String         @id @default(uuid()) @db.Uuid
  email              String         @unique
  pseudo             String
  mdp                String
  role               Role           @default(JOUEUR)
  personnages        Personnage[]
}

model Personnage{
  id                 String         @id @default(uuid()) @db.Uuid
  nom                String         @unique
  classe             Classe
  niveau             Int            @default(1)
  piecesDOr          Int            @default(0)
  pointsDeVie        Int            @default(100)
  idUtilisateur      String         @db.Uuid
  utilisateur        Utilisateur    @relation(fields: [idUtilisateur], references: [id], onDelete: Cascade)
  PersoQuetes      PersoQuete[]
  inventaire         Inventaire[]
}

model Quete{
  id                 String         @id @default(uuid()) @db.Uuid
  nom                String         @unique
  difficulte         Difficulte   
  recompense         Int
  PersoQuetes      PersoQuete[]  //Oui....une liste de journal, parce que chaque quete peut etre dans plusieurs entree de PersoQuete
}

model PersoQuete{
  id                 String         @id @default(uuid()) @db.Uuid
  idQuete            String         @db.Uuid
  statut             Statut         @default(DISPONIBLE)
  quete              Quete          @relation(fields: [idQuete], references: [id])
  idPersonnage       String         @db.Uuid
  personnage         Personnage     @relation(fields: [idPersonnage], references: [id], onDelete: Cascade)
  @@unique([idPersonnage, idQuete])
}

model Inventaire{
  id                 String         @id @default(uuid()) @db.Uuid
  idObjet            String         @db.Uuid
  objet              Objet          @relation(fields: [idObjet], references: [id])
  idPersonnage       String         @db.Uuid
  personnage         Personnage     @relation(fields: [idPersonnage], references: [id], onDelete: Cascade)
  @@unique([idPersonnage, idObjet])
}
